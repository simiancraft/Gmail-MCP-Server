{
  "name": "gmail-mcp-server",
  "version": "1.1.11",
  "description": "Gmail MCP server with auto authentication support",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gmail-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "bun dist/index.js",
    "auth": "bun dist/index.js auth",
    "prepare": "bun run build",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "gmail",
    "mcp",
    "cursor",
    "ai",
    "oauth",
    "model-context-protocol",
    "google-gmail",
    "claude",
    "auto-auth"
  ],
  "contributors": [
    "gongrzhe",
    {
      "name": "the-simian",
      "email": "harlinjesse@gmail.com"
    }
  ],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simiancraft/Gmail-MCP-Server.git"
  },
  "bugs": {
    "url": "https://github.com/simiancraft/Gmail-MCP-Server/issues"
  },
  "homepage": "https://github.com/simiancraft/Gmail-MCP-Server#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0",
    "@types/mime-types": "^2.1.4",
    "google-auth-library": "^9.4.1",
    "googleapis": "^129.0.0",
    "mime-types": "^3.0.1",
    "nodemailer": "^7.0.3",
    "open": "^10.0.0",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.22.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.17",
    "semantic-release": "^25.0.3",
    "typescript": "^5.3.3"
  }
}
